@app.route('/')
def index():
    return render_template_string(HTML_PAGE)

@app.route('/api/tracks')
def get_tracks():
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/getUpdates"
    resp = requests.get(url).json()
    
    tracks = []
    seen_ids = set()
    
    if resp.get('ok'):
        for update in resp.get('result', []):
            msg = update.get('channel_post')
            if not msg:
                continue
            if str(msg.get('chat', {}).get('id')) != str(CHANNEL_ID):
                continue
                
            if 'audio' in msg:
                audio = msg['audio']
                file_id = audio['file_id']
                if file_id not in seen_ids:
                    seen_ids.add(file_id)
                    tracks.append({
                        'file_id': file_id,
                        'title': audio.get('title', 'Без названия'),
                        'artist': audio.get('performer', 'Неизвестно'),
                        'duration': audio.get('duration', 0)
                    })
            elif 'voice' in msg:
                voice = msg['voice']
                file_id = voice['file_id']
                if file_id not in seen_ids:
                    seen_ids.add(file_id)
                    tracks.append({
                        'file_id': file_id,
                        'title': 'Голосовое сообщение',
                        'artist': '',
                        'duration': voice.get('duration', 0)
                    })
    
    return jsonify(tracks[::-1])

@app.route('/api/play/<file_id>')
def play_file(file_id):
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/getFile?file_id={file_id}"
    resp = requests.get(url).json()
    
    if resp.get('ok'):
        file_path = resp['result']['file_path']
        file_url = f"https://api.telegram.org/file/bot{BOT_TOKEN}/{file_path}"
        
        with requests.get(file_url, stream=True, headers={'User-Agent': 'Mozilla/5.0'}) as r:
            return Response(stream_with_context(r.iter_content(chunk_size=8192)), content_type=r.headers.get('Content-Type', 'audio/mpeg'))
            
    return jsonify({"error": "File not found"}), 404

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=8080)
